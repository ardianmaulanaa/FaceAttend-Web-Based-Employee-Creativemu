generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String  @id @default(uuid()) @db.Char(36)
  employee_code String? @unique @db.VarChar(30)

  name          String @db.VarChar(100)
  email         String @unique @db.VarChar(100)
  password_hash String @db.VarChar(255)

  // owner, admin, cs, employee
  role String @default("employee") @db.VarChar(20)

  // utama, magang
  employee_type String @default("utama") @db.VarChar(20)

  phone  String? @db.VarChar(20)
  status String  @default("active") @db.VarChar(20)

  profile_photo String? @db.VarChar(255)

  unit_id       String? @db.Char(36)
  department_id String? @db.Char(36)
  position_id   String? @db.Char(36)
  shift_id      String? @db.Char(36)

  // Kantor utama / kantor asal karyawan
  registered_office_id String? @db.Char(36)

  // Data pajak / payroll
  npwp_number String?  @db.VarChar(30)
  ptkp_status String?  @db.VarChar(20) // TK0, K0, K1, K2, K3
  base_salary Decimal? @db.Decimal(15, 2)

  unit              Unit?           @relation(fields: [unit_id], references: [id], onDelete: SetNull)
  department        Department?     @relation(fields: [department_id], references: [id], onDelete: SetNull)
  position          Position?       @relation(fields: [position_id], references: [id], onDelete: SetNull)
  shift             Shift?          @relation(fields: [shift_id], references: [id], onDelete: SetNull)
  registered_office OfficeLocation? @relation("EmployeeRegisteredOffice", fields: [registered_office_id], references: [id], onDelete: SetNull)

  attendances          Attendance[]
  attendance_summaries AttendanceMonthlySummary[]

  announcements  Announcement[] @relation("AnnouncementAuthor")
  leave_requests LeaveRequest[]

  visits EmployeeVisit[]

  wfh_requests          WfhRequest[] @relation("WfhRequestUser")
  approved_wfh_requests WfhRequest[] @relation("WfhApprovedBy")

  payrolls Payroll[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([role])
  @@index([employee_type])
  @@map("users")
}

model Unit {
  id String @id @default(uuid()) @db.Char(36)

  name String @unique @db.VarChar(100)

  // active, inactive
  status String @default("active") @db.VarChar(20)

  users       User[]
  departments Department[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model Department {
  id   String @id @default(uuid()) @db.Char(36)
  name String @db.VarChar(100)

  unit_id String? @db.Char(36)
  unit    Unit?   @relation(fields: [unit_id], references: [id], onDelete: SetNull)

  shift_id String? @db.Char(36)
  shift    Shift?  @relation(fields: [shift_id], references: [id], onDelete: SetNull)

  // monthly, daily, hourly
  salary_calculation String @default("monthly") @db.VarChar(30)

  // active, inactive
  status String @default("active") @db.VarChar(20)

  users     User[]
  positions Position[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([unit_id, name])
}

model Position {
  id String @id @default(uuid()) @db.Char(36)

  name String @db.VarChar(100)

  department_id String?     @db.Char(36)
  department    Department? @relation(fields: [department_id], references: [id], onDelete: SetNull)

  // active, inactive
  status String @default("active") @db.VarChar(20)

  users User[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([department_id, name])
}

model Shift {
  id String @id @default(uuid()) @db.Char(36)

  // Contoh: Utama, Magang, Shift A, Shift B
  name String @unique @db.VarChar(100)

  // Toleransi telat dalam menit
  tolerance_minutes Int @default(0)

  // active, inactive
  status String @default("active") @db.VarChar(20)

  users          User[]
  departments    Department[]
  work_schedules WorkSchedule[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model WorkSchedule {
  id String @id @default(uuid()) @db.Char(36)

  shift_id String @db.Char(36)
  shift    Shift  @relation(fields: [shift_id], references: [id], onDelete: Cascade)

  day_of_week DayOfWeek
  is_work_day Boolean   @default(true)

  check_in_time  String? @db.VarChar(5)
  check_out_time String? @db.VarChar(5)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([shift_id, day_of_week])
}

model OfficeLocation {
  id String @id @default(uuid()) @db.Char(36)

  name    String  @unique @db.VarChar(100)
  address String? @db.VarChar(255)

  latitude      Float
  longitude     Float
  radius_meters Int   @default(100)

  status String @default("active") @db.VarChar(20)

  users User[] @relation("EmployeeRegisteredOffice")

  registered_attendances Attendance[] @relation("RegisteredOfficeAttendance")
  check_in_attendances   Attendance[] @relation("CheckInOfficeAttendance")
  check_out_attendances  Attendance[] @relation("CheckOutOfficeAttendance")

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model Attendance {
  id String @id @default(uuid()) @db.Char(36)

  user_id String @db.Char(36)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  attendance_date DateTime @db.Date

  scheduled_check_in  DateTime?
  scheduled_check_out DateTime?

  check_in_time  DateTime?
  check_out_time DateTime?

  check_in_photo  Bytes?
  check_out_photo Bytes?

  check_in_photo_mime  String? @db.VarChar(50)
  check_out_photo_mime String? @db.VarChar(50)

  // office, wfh, visit
  work_mode String @default("office") @db.VarChar(20)

  // Kantor asal karyawan saat absensi dibuat
  registered_office_id String?         @db.Char(36)
  registered_office    OfficeLocation? @relation("RegisteredOfficeAttendance", fields: [registered_office_id], references: [id], onDelete: SetNull)

  // Kantor aktual saat check-in
  check_in_office_id String?         @db.Char(36)
  check_in_office    OfficeLocation? @relation("CheckInOfficeAttendance", fields: [check_in_office_id], references: [id], onDelete: SetNull)

  check_in_latitude      Float?
  check_in_longitude     Float?
  check_in_accuracy      Float?
  check_in_distance      Float?
  check_in_within_radius Boolean @default(false)

  // Kantor aktual saat check-out
  check_out_office_id String?         @db.Char(36)
  check_out_office    OfficeLocation? @relation("CheckOutOfficeAttendance", fields: [check_out_office_id], references: [id], onDelete: SetNull)

  check_out_latitude      Float?
  check_out_longitude     Float?
  check_out_accuracy      Float?
  check_out_distance      Float?
  check_out_within_radius Boolean @default(false)

  late_minutes        Int @default(0)
  late_seconds        Int @default(0)
  early_leave_minutes Int @default(0)
  work_minutes        Int @default(0)

  // true jika telat melewati toleransi shift
  is_over_tolerance Boolean @default(false)

  // alasan wajib jika telat melewati toleransi
  late_reason String? @db.VarChar(255)

  // alasan jika pulang cepat
  early_leave_reason String? @db.VarChar(255)

  // WFH / Kunjungan
  is_wfh   Boolean @default(false)
  is_visit Boolean @default(false)

  wfh_request_id String?     @db.Char(36)
  wfh_request    WfhRequest? @relation(fields: [wfh_request_id], references: [id], onDelete: SetNull)

  activity_note String? @db.VarChar(255)

  status           AttendanceStatus @default(PENDING)
  check_in_status  CheckInStatus?
  check_out_status CheckOutStatus?

  note String? @db.VarChar(255)

  visits EmployeeVisit[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, attendance_date])
  @@index([attendance_date])
  @@index([status])
  @@index([check_in_status])
  @@index([check_out_status])
  @@index([work_mode])
  @@index([is_wfh])
  @@index([is_visit])
}

model AttendanceMonthlySummary {
  id String @id @default(uuid()) @db.Char(36)

  user_id String @db.Char(36)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  period_month Int
  period_year  Int

  total_present_days Int @default(0)
  total_late_days    Int @default(0)
  total_absent_days  Int @default(0)
  total_leave_days   Int @default(0)
  total_sick_days    Int @default(0)

  total_late_minutes        Int @default(0)
  total_early_leave_minutes Int @default(0)
  total_work_minutes        Int @default(0)

  total_wfh_days   Int @default(0)
  total_visit_days Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, period_month, period_year])
  @@index([period_month, period_year])
}

model EmployeeVisit {
  id String @id @default(uuid()) @db.Char(36)

  user_id String @db.Char(36)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  attendance_id String?     @db.Char(36)
  attendance    Attendance? @relation(fields: [attendance_id], references: [id], onDelete: SetNull)

  visit_date DateTime @db.Date

  title       String  @db.VarChar(150)
  client_name String? @db.VarChar(100)
  address     String? @db.VarChar(255)

  latitude  Float?
  longitude Float?
  accuracy  Float?

  start_time DateTime?
  end_time   DateTime?

  note String? @db.VarChar(255)

  visit_photo      Bytes?
  visit_photo_mime String? @db.VarChar(50)

  // planned, ongoing, completed, cancelled
  status String @default("planned") @db.VarChar(20)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([visit_date])
  @@index([status])
}

model WfhRequest {
  id String @id @default(uuid()) @db.Char(36)

  user_id String @db.Char(36)
  user    User   @relation("WfhRequestUser", fields: [user_id], references: [id], onDelete: Cascade)

  request_date DateTime @db.Date

  reason String @db.Text

  // pending, approved, rejected
  status String @default("pending") @db.VarChar(20)

  // Radius khusus WFH jika disetujui admin / owner
  allowed_radius_meters Int? @default(500)

  approved_by_id String? @db.Char(36)
  approved_by    User?   @relation("WfhApprovedBy", fields: [approved_by_id], references: [id], onDelete: SetNull)

  admin_note String? @db.VarChar(255)

  attendances Attendance[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([request_date])
  @@index([status])
}

model LeaveRequest {
  id String @id @default(uuid()) @db.Char(36)

  user_id String @db.Char(36)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // annual, permission, sick, overtime, visit, wfh, other
  leave_type String @db.VarChar(30)

  // office, wfh, visit, flexible
  requested_work_mode String? @db.VarChar(20)

  // Jika true, approval admin membuka kunci lokasi untuk tanggal pengajuan.
  location_unlock_requested Boolean @default(false)
  location_unlock_approved  Boolean @default(false)

  visit_location_name String? @db.VarChar(150)
  visit_address       String? @db.VarChar(255)
  visit_latitude      Float?
  visit_longitude     Float?

  start_date DateTime @db.Date
  end_date   DateTime @db.Date
  total_days Int      @default(1)

  reason String @db.Text

  // pending, approved, rejected
  status String @default("pending") @db.VarChar(20)

  admin_note String? @db.VarChar(255)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([status])
  @@index([start_date])
  @@index([leave_type])
  @@index([location_unlock_approved])
}

model Announcement {
  id String @id @default(uuid()) @db.Char(36)

  title   String @db.VarChar(150)
  content String @db.Text

  // all, employee, admin, cs
  target String @default("all") @db.VarChar(20)

  // published, draft, archived
  status String @default("published") @db.VarChar(20)

  author_id String? @db.Char(36)
  author    User?   @relation("AnnouncementAuthor", fields: [author_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@index([target])
  @@index([status])
  @@index([created_at])
}

model Payroll {
  id String @id @default(uuid()) @db.Char(36)

  user_id String @db.Char(36)
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  period_month Int
  period_year  Int

  base_salary Decimal @default(0) @db.Decimal(15, 2)

  total_bonus     Decimal @default(0) @db.Decimal(15, 2)
  total_reward    Decimal @default(0) @db.Decimal(15, 2)
  leave_deduction Decimal @default(0) @db.Decimal(15, 2)
  late_deduction  Decimal @default(0) @db.Decimal(15, 2)
  other_deduction Decimal @default(0) @db.Decimal(15, 2)

  gross_salary Decimal @default(0) @db.Decimal(15, 2)

  // Pajak PPH
  pph_amount Decimal @default(0) @db.Decimal(15, 2)

  net_salary Decimal @default(0) @db.Decimal(15, 2)

  total_late_minutes Int @default(0)
  total_work_minutes Int @default(0)
  total_absent_days  Int @default(0)
  total_leave_days   Int @default(0)

  // draft, finalized, paid
  status String @default("draft") @db.VarChar(20)

  items PayrollItem[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  @@unique([user_id, period_month, period_year])
  @@index([period_month, period_year])
  @@index([status])
}

model PayrollItem {
  id String @id @default(uuid()) @db.Char(36)

  payroll_id String  @db.Char(36)
  payroll    Payroll @relation(fields: [payroll_id], references: [id], onDelete: Cascade)

  // bonus, reward, leave_deduction, late_deduction, pph, other_deduction
  type String @db.VarChar(30)

  name String @db.VarChar(100)

  amount Decimal @default(0) @db.Decimal(15, 2)

  note String? @db.VarChar(255)

  created_at DateTime @default(now())

  @@index([type])
}

model Permission {
  id String @id @default(uuid()) @db.Char(36)

  name String @unique @db.VarChar(100)
  code String @unique @db.VarChar(100)

  role_permissions RolePermission[]

  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}

model RolePermission {
  id String @id @default(uuid()) @db.Char(36)

  // owner, admin, cs, employee
  role String @db.VarChar(20)

  permission_id String     @db.Char(36)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  created_at DateTime @default(now())

  @@unique([role, permission_id])
  @@index([role])
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PENDING
  PRESENT
  LATE
  ABSENT
  PERMISSION
  SICK
}

enum CheckInStatus {
  ON_TIME
  LATE
}

enum CheckOutStatus {
  NORMAL
  EARLY
}
