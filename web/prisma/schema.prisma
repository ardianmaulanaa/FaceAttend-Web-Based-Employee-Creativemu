// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id                   String   @id @default(uuid()) @db.Char(36)
  name                 String   @db.VarChar(100)
  email                String   @unique @db.VarChar(100)
  password_hash        String   @db.VarChar(255)
  role                 String   @default("employee") @db.VarChar(20)
  department           String?  @db.VarChar(100)
  position             String?  @db.VarChar(100)
  phone                String?  @db.VarChar(20)
  employee_category    String   @default("tetap") @db.VarChar(30)
  city_id              String?  @db.VarChar(36)
  village_id           String?  @db.VarChar(36)
  status               String   @default("active") @db.VarChar(20)
  face_registered      Boolean  @default(false)
  reward_points        Int      @default(0)
  payout_label         String?  @db.VarChar(100)
  account_holder_name  String?  @db.VarChar(100)
  payout_contact_email String?  @db.VarChar(100)
  payout_phone_number  String?  @db.VarChar(30)
  account_number       String?  @db.VarChar(80)
  expiry_month         String?  @db.VarChar(10)
  expiry_year          String?  @db.VarChar(10)
  cvc                  String?  @db.VarChar(10)
  must_change_password Boolean  @default(true)
  created_at           DateTime @default(now())
  attendances          Attendance[]

  @@map("users")
}

model Attendance {
  id                  String    @id @default(uuid()) @db.Char(36)
  employee_id         String    @db.Char(36)
  attendance_date     DateTime  @db.Date
  check_in_time       DateTime? @db.DateTime(3)
  check_out_time      DateTime? @db.DateTime(3)
  check_in_photo_url  String?   @db.LongText
  check_out_photo_url String?   @db.LongText
  check_in_latitude   Decimal?  @db.Decimal(10, 6)
  check_in_longitude  Decimal?  @db.Decimal(10, 6)
  check_out_latitude  Decimal?  @db.Decimal(10, 6)
  check_out_longitude Decimal?  @db.Decimal(10, 6)
  notes               String?   @db.VarChar(255)
  created_at          DateTime  @default(now()) @db.DateTime(3)
  updated_at          DateTime  @updatedAt @db.DateTime(3)

  employee User @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@unique([employee_id, attendance_date])
  @@index([attendance_date])
  @@map("attendances")
}